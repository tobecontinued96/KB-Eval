# 本地 docker-compose Postgres 默认值，可直接 `cp .env.example .env` 后用。
# 真实凭据请放 .env（已在 .gitignore 之外时由 docker compose / 后端进程读）。
POSTGRES_DB=dify_kb_eval
POSTGRES_USER=dify_kb_eval
POSTGRES_PASSWORD=dify_kb_eval
DATABASE_URL=postgresql+asyncpg://dify_kb_eval:dify_kb_eval@127.0.0.1:5555/dify_kb_eval

# Docker one-click deployment defaults.
FRONTEND_PORT=5598
BACKEND_PORT=8200
DOCKER_NETWORK_NAME=dify-kb-eval-net

# Domestic mirrors used by docker compose builds. Override these in .env if a
# mirror is temporarily unavailable, or set them back to official images.
POSTGRES_IMAGE=m.daocloud.io/docker.io/library/postgres:16
PYTHON_IMAGE=m.daocloud.io/docker.io/library/python:3.12-slim
NODE_IMAGE=m.daocloud.io/docker.io/library/node:22-alpine
NGINX_IMAGE=m.daocloud.io/docker.io/library/nginx:1.27-alpine
APT_MIRROR=http://mirrors.aliyun.com/debian
APT_SECURITY_MIRROR=http://mirrors.aliyun.com/debian-security
PYPI_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
NPM_REGISTRY=https://registry.npmmirror.com

# Schema lifecycle policy.
#
# true  (default, dev-friendly): backend/app.py lifespan calls
#       ``Base.metadata.create_all`` on startup. New tables appear
#       automatically, but new *columns on existing tables* do NOT --
#       that's the gotcha alembic exists to fix. Use this in dev /
#       CI / on your laptop.
#
# false (required for production): lifespan refuses to start unless
#       ``alembic_version`` is at head. The deploy pipeline must run
#       ``alembic upgrade head`` before / as part of starting the
#       backend. See ``scripts/migrations/LEGACY.md`` for the
#       onboarding recipe and ``backend/app.py`` lifespan for the
#       runtime check.
RUN_DB_BOOTSTRAP=true
RUN_DB_MIGRATIONS=true
RUN_DB_INIT_ON_EMPTY=true
RUN_DB_STAMP_HEAD_ON_INIT=true
